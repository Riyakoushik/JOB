generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Job {
  id           String   @id @default(cuid())
  title        String
  company      String
  source       String
  category     String?
  tier         String?
  skills       String @default("[]")
  experience   String?
  location     String?
  url          String
  description  String?
  postedAt     DateTime?
  fetchTime    DateTime @default(now())
  
  @@unique([url])
}

model HRContact {
  id           String   @id @default(cuid())
  name         String
  company      String
  role         String?
  linkedin     String?
  email        String?
  lastUpdated  DateTime @default(now())

  @@unique([linkedin])
}

model ScraperLog {
  id           String   @id @default(cuid())
  runTime      DateTime @default(now())
  source       String
  status       String   // "SUCCESS" or "ERROR"
  jobsAdded    Int      @default(0)
  errors       String?
}
